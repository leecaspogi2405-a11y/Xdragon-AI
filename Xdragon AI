<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Free AI</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: #121212; color: #e0e0e0; margin: 0; display: flex; flex-direction: column; height: 100vh; }
        header { background-color: #1f1f1f; padding: 15px; text-align: center; font-size: 1.2rem; font-weight: bold; border-bottom: 1px solid #333; }
        #chat-container { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 15px; }
        .message { max-width: 75%; padding: 12px 16px; border-radius: 15px; line-height: 1.4; word-wrap: break-word; }
        .user-message { background-color: #007acc; color: white; align-self: flex-end; border-bottom-right-radius: 2px; }
        .ai-message { background-color: #2d2d2d; color: #e0e0e0; align-self: flex-start; border-bottom-left-radius: 2px; }
        #input-container { background-color: #1f1f1f; padding: 15px; display: flex; gap: 10px; border-top: 1px solid #333; }
        input { flex: 1; background-color: #2d2d2d; border: 1px solid #444; color: white; padding: 12px; border-radius: 8px; outline: none; }
        input:focus { border-color: #007acc; }
        button { background-color: #007acc; color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; }
        button:hover { background-color: #005999; }
    </style>
</head>
<body>

    <header>🤖 My Free AI Assistant</header>

    <div id="chat-container">
        <div class="message ai-message">Hello! I am your AI. Feel free to ask me anything!</div>
    </div>

    <div id="input-container">
        <input type="text" id="user-input" placeholder="Type a message here..." onkeydown="if(event.key === 'Enter') sendMessage()">
        <button onclick="sendMessage()">Send</button>
    </div>

    <script>
        // ⚠️ REPLACE THIS: Insert your API Key inside the quotes
        const API_KEY = "AIzaSyAgwi93gsiaEiSiO53jrleXyNwQKQRLIY8"; 
        const API_URL = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${API_KEY}`;

        async function sendMessage() {
            const inputField = document.getElementById("user-input");
            const chatContainer = document.getElementById("chat-container");
            const messageText = inputField.value.trim();

            if (messageText === "") return;

            // 1. Display User's chat message
            appendMessage(messageText, "user-message");
            inputField.value = "";

            // 2. Set loading status for the AI
            const loadingDiv = appendMessage("Thinking...", "ai-message");

            try {
                // 3. Call the Google Gemini API
                const response = await fetch(API_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: messageText }] }]
                    })
                });

                const data = await response.json();
                
                // 4. Get the AI's response and display it
                const aiResponse = data.candidates[0].content.parts[0].text;
                loadingDiv.innerText = aiResponse;

            } catch (error) {
                console.error("Error:", error);
                loadingDiv.innerText = "Oh no, an error occurred! Please check your API key or internet connection.";
            }

            // Auto-scroll to the bottom
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        function appendMessage(text, className) {
            const chatContainer = document.getElementById("chat-container");
            const messageDiv = document.createElement("div");
            messageDiv.className = `message ${className}`;
            messageDiv.innerText = text;
            chatContainer.appendChild(messageDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
            return messageDiv;
        }
    </script>
</body>
</html>
